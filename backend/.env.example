DATABASE_URL="file:./dev.db"
PORT=5000
JWT_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
NODE_ENV="development"

# Google Gemini (AI Studio API key)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Optional: Vertex tuned model resource name if using GCP tuning (separate auth may be required)
GEMINI_TUNED_MODEL=""

# Client file drop folder for training scans
# TRAINING_DROP_FOLDER="/path/to/client/drop/folder"
# CLIENT_DROP_FOLDER="/path/to/client/drop/folder"
